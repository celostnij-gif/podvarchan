# ============================================
# Podvarchan.com — переменные окружения
# Скопируй этот файл как .env.local и заполни
# ============================================

# --- Сайт ---
NEXT_PUBLIC_SITE_URL=https://podvarchan.com
GOOGLE_SITE_VERIFICATION=

# --- Google Analytics 4 ---
# Measurement ID из панели администрирования GA4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Cloudflare Turnstile (CAPTCHA) ---
# Публичный ключ из Cloudflare Dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
# Секретный ключ — показывается один раз при создании виджета
TURNSTILE_SECRET_KEY=0x4AAAA...

# --- Resend (email-рассылка) ---
# API-ключ из resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email, на который приходят заявки из формы контактов
CONTACT_EMAIL=your@email.com
# Отправитель (опционально, по умолчанию noreply@podvarchan.com)
# EMAIL_FROM=noreply@podvarchan.com
# Получатель уведомлений (опционально, по умолчанию podvarchan@gmail.com)
# EMAIL_TO=podvarchan@gmail.com

# ============================================
# АДМИН-ПАНЕЛЬ
# ============================================

# --- База данных Cloudflare D1 ---
# DATABASE_URL=your_d1_database_url
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_DATABASE_ID=your_d1_database_id

# --- NextAuth v4 ---
# Абсолютный URL сайта (для корректной работы NextAuth callback'ов)
NEXTAUTH_URL=https://podvarchan.com
# Секретный ключ для JWT (минимум 32 символа, openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_at_least_32_chars

# --- Seed-пользователь (администратор) ---
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=your_secure_password_at_least_8_chars

# --- Cloudflare R2 (хранилище медиафайлов) ---
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# NEXT_PUBLIC_MEDIA_BASE_URL=https://pub-xxxxx.r2.dev
