# ============================================
# Podvarchan.com — переменные окружения
# Скопируй этот файл как .env.local и заполни
# ============================================

# --- Сайт ---
NEXT_PUBLIC_SITE_URL=https://podvarchan.com

# --- Google Analytics 4 ---
# Measurement ID из панели администрирования GA4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Cloudflare Turnstile (CAPTCHA) ---
# Публичный ключ из Cloudflare Dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
# Секретный ключ — показывается один раз при создании виджета
TURNSTILE_SECRET_KEY=0x4AAAA...

# --- Resend (email-рассылка) ---
# API-ключ из resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email, на который приходят заявки из формы контактов
CONTACT_EMAIL=your@email.com

# --- NextAuth (админ-панель) ---
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=your_secret_here
# Обязательно для Cloudflare Workers
AUTH_TRUST_HOST=true

# --- Admin seed (OWNER пользователь) ---
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=your_secure_password

# --- Cloudflare D1 (drizzle-kit) ---
# Cloudflare Account ID (Dashboard → Workers → справа)
CLOUDFLARE_ACCOUNT_ID=your_account_id
# ID базы D1 (Cloudflare Dashboard → D1 → podvarchan-db)
CLOUDFLARE_DATABASE_ID=your_database_id

# API-токен Cloudflare (для drizzle-kit push/seed)
CLOUDFLARE_API_TOKEN=your_api_token
