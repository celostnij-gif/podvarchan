{
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "next dev",
    "dev:admin": "cd apps/admin && next dev --port 3001",
    "build": "npx opennextjs-cloudflare build",
    "build:admin": "cd apps/admin && npx opennextjs-cloudflare build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "deploy": "npx opennextjs-cloudflare build && npx wrangler deploy",
    "deploy:admin": "cd apps/admin && npx opennextjs-cloudflare build && npx wrangler deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply podvarchan --local",
    "db:migrate:prod": "wrangler d1 migrations apply podvarchan",
    "db:seed": "cd apps/admin && tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/language-server": "^0.14.29",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@podvarchan/shared": "workspace:*",
    "@stablelib/nacl": "^2.0.1",
    "@swc/helpers": "^0.5.23",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "^15.5.18",
    "next-intl": "^4.12.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tweetnacl": "^1.0.3",
    "zod": "^4.4.3"
  }
}
